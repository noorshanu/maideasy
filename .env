# Google Sheets (Service Account)
# 1. Create a Google Cloud project + enable Google Sheets API
# 2. Create a Service Account and download JSON key
# 3. Share your Google Sheet with the service account email (Editor)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_from_url
GOOGLE_SHEET_RANGE=Bookings!A:Z

# WhatsApp Cloud API (Meta Business)
# 1. Create Meta App → WhatsApp product
# 2. Get permanent access token + Phone Number ID
WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# Optional: also send PDF to admin/office number (E.164 digits only, e.g. 919061222123)
WHATSAPP_ADMIN_PHONE=919061222123
NEXT_PUBLIC_GSHEET_WEBHOOK=https://script.google.com/macros/s/AKfycbxnpbDKZv1LOz23z_P5Rrc-5HKT1TPn1ZjrzrQVjqvMHxwriWj9dX-wlaMggKvAgfzLWQ/exec
